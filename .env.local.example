# ── AI ──────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here

# ── Market ───────────────────────────────────────
GOLD_API_KEY=your_goldapi_key_here          # goldapi.io
COINGECKO_API_KEY=your_coingecko_key_here   # free tier OK, add for higher limit

# ── GitHub ───────────────────────────────────────
GITHUB_TOKEN=your_github_pat_here           # Settings → Developer settings → PAT
GITHUB_USERNAME=NMQuang        # e.g. your_handle

# ── Dify ─────────────────────────────────────────
DIFY_API_KEY=your_dify_api_key_here
DIFY_BASE_URL=https://api.dify.ai/v1        # or your self-hosted URL

# ── Weather (OpenWeatherMap free tier) ───────────
WEATHER_API_KEY=your_openweathermap_key_here

# ── Supabase (server-side only — never expose to browser) ────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role key — NOT anon key>
SUPABASE_ACCESS_TOKEN=<personal access token>   # dùng cho npm run db:migrate
                                                 # lấy tại: https://supabase.com/dashboard/account/tokens

# ── Cron security ────────────────────────────────
CRON_SECRET=dashboard_hub_cron_secret                # must match Vercel env var

# ── App ──────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=dashboard-hub.hq
NEXT_PUBLIC_ONSITE_DATE=2025-07-01          # your actual Japan onsite date
NEXT_PUBLIC_GITHUB_USERNAME=NMQuang

# ── Family — Auth ─────────────────────────────────────────────────────────────
FAMILY_PASSWORD=your_family_password         # shared password for /family pages
FAMILY_COOKIE_SALT=dashboard-hub-family-2025 # salt for hashing the cookie

# ── Family — KV store (Upstash Redis REST API) ────────────────────────────────
# Create a free Redis DB at https://console.upstash.com → copy REST API URL + token
FAMILY_KV_REST_API_URL=https://<region>.upstash.io
FAMILY_KV_REST_API_TOKEN=<upstash-rest-token>

# ── Family — Cloudflare R2 (photo storage) ───────────────────────────────────
# Create bucket at https://dash.cloudflare.com → R2 → Create bucket
# Enable "Public access" on the bucket and copy the public URL / custom domain
R2_ACCOUNT_ID=<cloudflare-account-id>
R2_ACCESS_KEY_ID=<r2-access-key>
R2_SECRET_ACCESS_KEY=<r2-secret-key>
R2_BUCKET_NAME=family-photos
R2_PUBLIC_URL=https://pub-<hash>.r2.dev          # or your custom domain, NO trailing slash
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-<hash>.r2.dev  # same value — MUST match R2_PUBLIC_URL exactly

# ── Family — Google Photos (Picker API) ──────────────────────────────────────
# Create OAuth 2.0 credentials at https://console.cloud.google.com
# Enable "Photos Picker API" and "Photos Library API"
# Scopes: photospicker.mediaitems.readonly, photoslibrary.readonly
GOOGLE_CLIENT_ID=<your-oauth-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-oauth-client-secret>
GOOGLE_REFRESH_TOKEN=<refresh-token>     # obtained via /family/setup OAuth flow
